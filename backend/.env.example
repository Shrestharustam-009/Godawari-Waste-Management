# ============================================================================
# GODAWARI WASTE MANAGEMENT SYSTEM — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================================

# ── Database ──
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/godawari_wms?schema=public"

# ── Server ──
PORT=4000
NODE_ENV=development

# ── JWT Authentication ──
# CRITICAL: Generate a strong 256-bit secret for production.
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_IMMEDIATELY
JWT_EXPIRES_IN=8h

# ── CORS ──
CORS_ORIGIN=http://localhost:3000

JWT_EXPIRES_IN="2h"
COOKIE_MAX_AGE_MS=7200000

AUTH_RATE_LIMIT_MAX=20
